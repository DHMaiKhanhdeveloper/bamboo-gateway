{
  "name": "e2e_bamboo_gateway",
  "version": "1.0.0",
  "description": "Enterprise-grade E2E + API automated testing framework for BambooPay payment gateway",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --project=chromium-ui",
    "test:api": "playwright test --project=chromium-api",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:tickets": "playwright test --grep @ticket",
    "test:critical": "playwright test --grep @critical",
    "test:allure": "playwright test --reporter=allure-playwright",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:list": "playwright test --list",
    "test:suite": "tsx scripts/run-test-suite.ts",
    "ui": "playwright test --ui",
    "report:html": "playwright show-report reports/html",
    "report:merge": "playwright merge-reports --reporter=html ./blob-report -o reports/html",
    "allure:generate": "allure generate reports/allure-results --clean -o reports/allure-report",
    "allure:open": "allure open reports/allure-report",
    "allure:serve": "allure serve reports/allure-results",
    "auth": "tsx scripts/auth-manager.ts",
    "auth:login": "npm run auth -- login",
    "auth:clear": "npm run auth -- clear",
    "auth:status": "npm run auth -- status",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "validate": "npm run typecheck && npm run lint && npm run format:check",
    "deploy": "node scripts/deploy-with-history.js deploy",
    "deploy:validate": "node scripts/deploy-with-history.js validate",
    "deploy:summary": "node scripts/deploy-with-history.js summary",
    "download:github-pages": "node scripts/download-github-pages.js download",
    "merge:results": "node scripts/merge-test-results.js merge",
    "generate:manifest": "tsx scripts/generate-test-suites-manifest.ts",
    "aggregate": "tsx scripts/generate-suite-aggregation.ts",
    "demo": "node scripts/run-demo.js",
    "clean": "rimraf reports test-results blob-report .auth/*.json"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@faker-js/faker": "^10.0.0",
    "@playwright/test": "^1.55.1",
    "@types/node": "^24.5.2",
    "allure-commandline": "^2.34.1",
    "allure-playwright": "^3.4.1",
    "eslint": "^9.17.0",
    "eslint-plugin-playwright": "^2.1.0",
    "globals": "^15.14.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "zod": "^4.1.11"
  },
  "dependencies": {
    "dotenv": "^17.2.2",
    "otplib": "^12.0.1",
    "uuid": "^13.0.0"
  }
}
