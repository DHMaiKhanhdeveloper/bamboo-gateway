# =============================================================================
# Environment Variables for E2E Testing
# Copy this file to .env.local and fill in your actual values
# =============================================================================

# -----------------------------------------------------------------------------
# Base URLs
# -----------------------------------------------------------------------------
BASE_URL=https://portal.bamboopay-stage.com
API_BASE_URL=https://api.bamboopay-stage.com

# -----------------------------------------------------------------------------
# Authentication Credentials (REQUIRED)
# -----------------------------------------------------------------------------
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=your_admin_password
TOTP_SECRET=your_totp_secret_key

# -----------------------------------------------------------------------------
# CI/CD Environment (optional)
# Set to 'true' when running in CI/CD pipeline
# -----------------------------------------------------------------------------
CI=false

# -----------------------------------------------------------------------------
# Logging
# Levels: debug | info | warn | error
# -----------------------------------------------------------------------------
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Auth State Cache (optional)
# TTL in milliseconds (default: 900000 = 15 minutes)
# -----------------------------------------------------------------------------
AUTH_STATE_TTL_MS=900000

# -----------------------------------------------------------------------------
# Bypass Auth (Emergency Fallback - DO NOT USE IN CI)
# Use only when login API is broken; provide a manually obtained bearer token
# -----------------------------------------------------------------------------
# BYPASS_AUTH_TOKEN=
