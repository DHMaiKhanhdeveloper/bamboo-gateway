{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug current Playwright spec",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/@playwright/test/cli.js",
      "args": ["test", "${file}", "--headed", "--workers=1"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Debug all UI tests",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/@playwright/test/cli.js",
      "args": ["test", "--project=chromium-ui", "--workers=1"],
      "console": "integratedTerminal"
    },
    {
      "name": "Debug smoke suite",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/@playwright/test/cli.js",
      "args": ["test", "--grep", "@smoke", "--workers=1"],
      "console": "integratedTerminal"
    }
  ]
}
